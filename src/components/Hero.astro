<section id="inicio" class="relative py-16 md:py-24">
  <div class="container-premium grid items-center gap-12 lg:grid-cols-[1.02fr_0.98fr]">
    <div class="reveal show">
      <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-line bg-white/65 px-3.5 py-2 text-[13px] font-extrabold text-[#42556c] shadow-[0_12px_30px_rgb(7_26_47_/_0.06)]">
        <span class="signal-dot"></span> Atención privada · <b class="text-teal">Santa Fe, CDMX</b>
      </div>
      <h1 class="mb-7 max-w-4xl text-[48px] font-black leading-[0.92] tracking-[-0.08em] text-ink sm:text-[64px] lg:text-[88px]">
        Salud mental y cognitiva con una experiencia <span class="bg-gradient-to-br from-navy via-teal to-gold bg-clip-text text-transparent">médica premium.</span>
      </h1>
      <p class="mb-9 max-w-2xl text-lg text-muted md:text-xl">
        Una plataforma privada para un grupo de especialistas en neuropsiquiatría, psiquiatría clínica y neuropsicología en Santa Fe, CDMX. Agenda inteligente, perfiles médicos, orientación inicial y atención humana para pacientes y familias.
      </p>
      <div class="mb-9 flex flex-wrap gap-3.5">
        <button class="btn btn-primary js-open-modal" type="button">Agendar cita</button>
        <a class="btn btn-secondary" href="#especialidades">Explorar especialidades</a>
      </div>
      <div class="grid max-w-2xl grid-cols-3 gap-3.5 max-sm:grid-cols-1">
        {[
          ['6+', 'Especialidades'],
          ['48h', 'Respuesta sugerida'],
          ['ES/EN', 'Atención bilingue'],
        ].map(([value, label]) => (
          <div class="glass-card rounded-[22px] p-4">
            <strong class="block text-2xl font-black tracking-[-0.04em] text-navy">{value}</strong>
            <span class="block text-xs font-extrabold uppercase tracking-[0.08em] text-muted">{label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="reveal show relative grid min-h-[620px] place-items-center max-lg:min-h-[540px] max-sm:min-h-auto">
      <div class="absolute h-[560px] w-[560px] rounded-full bg-[conic-gradient(from_220deg,rgb(185_141_74_/_0.76),rgb(11_139_137_/_0.95),rgb(7_26_47_/_0.96),rgb(185_141_74_/_0.76))] opacity-90 blur-[0.2px] drop-shadow-[0_38px_70px_rgb(7_26_47_/_0.20)] max-sm:h-[330px] max-sm:w-[330px]"></div>
      <div class="relative w-full max-w-[520px] overflow-hidden rounded-[44px] border border-white/80 bg-white/78 p-5 shadow-premium backdrop-blur-2xl max-sm:rounded-[32px]">
        <div class="relative overflow-hidden rounded-[34px] bg-gradient-to-br from-navy to-navy-soft p-6 text-white max-sm:rounded-[26px]">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_64%_32%,rgb(88_209_201_/_0.20),transparent_170px)]"></div>
          <div class="relative mb-8 flex items-start justify-between gap-4">
            <div>
              <small class="text-xs font-extrabold uppercase tracking-[0.12em] text-white/60">Concierge médico</small>
              <h2 class="mt-1 text-3xl font-black tracking-[-0.05em]">Agenda inteligente</h2>
            </div>
            <div class="rounded-full border border-white/15 bg-white/10 px-3 py-2 text-xs font-extrabold text-white/80">Privado</div>
          </div>
          <div class="relative mx-auto grid h-48 w-60 place-items-center">
            <div class="absolute inset-4 rounded-full border border-champagne/40 rotate-[-12deg]"></div>
            <div class="absolute inset-x-1 inset-y-9 rounded-full border border-teal-soft/30 rotate-[32deg]"></div>
            <div class="h-32 w-40 rounded-[52%_46%_50%_48%] bg-gradient-to-br from-teal-soft to-white opacity-95 shadow-[0_0_45px_rgb(88_209_201_/_0.28)]"></div>
            <span class="absolute left-8 top-20 h-3 w-3 rounded-full bg-champagne shadow-[0_0_0_7px_rgb(227_201_142_/_0.12)]"></span>
            <span class="absolute right-10 top-10 h-3 w-3 rounded-full bg-champagne shadow-[0_0_0_7px_rgb(227_201_142_/_0.12)]"></span>
            <span class="absolute bottom-10 right-7 h-3 w-3 rounded-full bg-champagne shadow-[0_0_0_7px_rgb(227_201_142_/_0.12)]"></span>
          </div>
        </div>
        <div class="mt-4 grid gap-3">
          {[
            ['Primera vez presencial', 'Santa Fe · 60 min', 'Santa Fe'],
            ['Evaluación neuropsicológica', 'Memoria · Atención · TDAH', 'Alta demanda'],
            ['Seguimiento psiquiatrico', 'Presencial u online', 'ES/EN'],
          ].map(([title, meta, badge]) => (
            <div class="grid grid-cols-[1fr_auto] items-center gap-3 rounded-3xl border border-line bg-white p-4 shadow-[0_12px_32px_rgb(7_26_47_/_0.065)]">
              <div>
                <b class="block text-sm text-ink">{title}</b>
                <span class="block text-[13px] font-bold text-muted">{meta}</span>
              </div>
              <span class="rounded-full bg-[#effaf8] px-2.5 py-1.5 text-[11px] font-black uppercase tracking-[0.08em] text-teal">{badge}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
