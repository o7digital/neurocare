---
import { experienceCards } from '../data/site';
---

<section id="experiencia" class="section-premium">
  <div class="container-premium">
    <span class="eyebrow">Experiencia digital</span>
    <h2 class="section-title">No es una web. Es una recepción médica premium.</h2>
    <p class="lead">
      Disenada para transmitir confianza desde el primer segúndo, orientar al paciente, organizar solicitudes de cita y presentar al equipo médico con autoridad y cercania.
    </p>
    <div class="mt-12 grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="reveal flex min-h-[520px] flex-col justify-end overflow-hidden rounded-[42px] bg-[linear-gradient(180deg,rgb(7_26_47_/_0.12),rgb(7_26_47_/_0.76)),radial-gradient(circle_at_70%_26%,rgb(88_209_201_/_0.30),transparent_230px),linear-gradient(135deg,#12355b,#071a2f)] p-8 text-white shadow-premium">
        <h3 class="mb-4 max-w-2xl text-4xl font-black leading-none md:text-[42px]">Diseño editorial, sobrio y clínicamente responsable.</h3>
        <p class="max-w-2xl text-lg text-white/72">
          Ideal para médicos que buscan una presencia digital de reputacion, metodo y atención personalizada, sin parecer un consultorio generico.
        </p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-1">
        {experienceCards.map((card) => (
          <article class="reveal glass-card relative overflow-hidden rounded-[32px] p-7">
            <div class="mb-5 grid h-14 w-14 place-items-center rounded-2xl bg-gradient-to-br from-[#fff6e7] to-[#eafbfb] text-xl font-black text-teal">{card.icon}</div>
            <h3 class="mb-2 text-2xl font-black text-ink">{card.title}</h3>
            <p class="text-muted">{card.description}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
