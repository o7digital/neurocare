---
import { specialties } from '../data/site';
---

<section id="especialidades" class="section-premium relative overflow-hidden bg-navy text-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_16%_10%,rgb(227_201_142_/_0.18),transparent_340px),radial-gradient(circle_at_86%_50%,rgb(88_209_201_/_0.15),transparent_360px)]"></div>
  <div class="container-premium">
    <span class="eyebrow">Especialidades</span>
    <h2 class="section-title section-title-light">Arquitectura médica por servicio, perfil y necesidad del paciente.</h2>
    <p class="lead text-white/68">
      Cada bloque esta preparado para convertirse en una página SEO independiente con CTA, médico responsable, preguntas frecuentes y agenda filtrada.
    </p>
    <div class="mt-12 grid gap-6 lg:grid-cols-[360px_1fr]">
      <div class="grid content-start gap-3" role="tablist" aria-label="Especialidades médicas">
        {specialties.map((specialty, index) => (
          <button
            class:list={['specialty-tab rounded-3xl border p-5 text-left transition', index === 0 ? 'active border-champagne/35 bg-gradient-to-br from-teal/45 to-gold/20' : 'border-white/12 bg-white/[0.055] hover:bg-white/10']}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            data-tab={index}
          >
            <b class="block text-base">{specialty.title}</b>
            <span class="mt-1 block text-[13px] text-white/58">{specialty.slug}</span>
          </button>
        ))}
      </div>
      <div>
        {specialties.map((specialty, index) => (
          <article class:list={['specialty-panel min-h-[520px] rounded-[42px] border border-white/14 bg-white/[0.08] p-8 shadow-[0_30px_80px_rgb(0_0_0_/_0.25)] backdrop-blur-xl', index === 0 ? 'grid' : 'hidden']} data-panel={index}>
            <div class="grid items-center gap-8 lg:grid-cols-[1fr_0.8fr]">
              <div>
                <p class="mb-3 text-sm font-black uppercase tracking-[0.16em] text-champagne">Servicio preparado para SEO</p>
                <h3 class="mb-4 text-4xl font-black leading-none md:text-5xl">{specialty.title}</h3>
                <p class="text-lg text-white/72">{specialty.summary}</p>
                <div class="mt-6 grid gap-3">
                  {specialty.bullets.map((bullet) => (
                    <div class="rounded-2xl border border-white/10 bg-white/[0.07] p-4 font-bold text-white/84">✓ {bullet}</div>
                  ))}
                </div>
                <button class="btn btn-primary js-open-modal mt-7" type="button">Solicitar cita</button>
              </div>
              <div class="grid min-h-[360px] place-items-center overflow-hidden rounded-[34px] border border-white/14 bg-[radial-gradient(circle_at_50%_40%,rgb(88_209_201_/_0.38),transparent_150px),linear-gradient(135deg,rgb(255_255_255_/_0.10),rgb(255_255_255_/_0.035))]">
                <div class="grid h-36 w-36 place-items-center rounded-full bg-gradient-to-br from-teal-soft to-champagne text-5xl font-black text-navy shadow-[0_0_60px_rgb(88_209_201_/_0.24)]">{String(index + 1).padStart(2, '0')}</div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
